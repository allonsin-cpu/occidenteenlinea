(function(){"use strict";try{if(typeof document<"u"){var e=document.createElement("style");e.appendChild(document.createTextNode('.product-experience-manager-cookie-banner{background-color:#234584;bottom:0;box-shadow:0 16px 48px #0000002d;color:#fff;display:flex;font-family:system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen-Sans,Ubuntu,Cantarell,Helvetica Neue,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji",Segoe UI Symbol;left:0;min-height:146px;padding:10px 0;position:fixed;width:100%;z-index:999}.product-experience-manager-cookie-banner a{color:#fff;text-decoration:underline}.product-experience-manager-cookie-banner__container{align-items:center;display:flex;margin:0 auto;padding:1.5rem 100px;width:100%}.product-experience-manager-cookie-banner__box-content{flex:1;margin-right:136px}.product-experience-manager-cookie-banner__box-content__title{font-size:18px;font-weight:600;margin-bottom:8px}.product-experience-manager-cookie-banner__box-content__description{font-size:14px}.product-experience-manager-cookie-banner__button{background-color:#fff;border-radius:2px;color:#6b6c7e;font-size:.875rem;font-weight:600;line-height:1.15;padding:.4375rem .75rem;border:0 none;transition:color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out}.product-experience-manager-cookie-banner__button:hover{color:#333}.product-experience-manager-cookie-banner__buttons{display:flex;gap:16px}.product-experience-manager-cookie-banner__show-more-button{text-transform:uppercase;display:block;margin-top:16px;background-color:transparent;border:0 none;color:#fff;padding:0}@media (max-width: 768px){.product-experience-manager-cookie-banner__container{display:block;padding:16px}.product-experience-manager-cookie-banner__box-content{margin-right:0}.product-experience-manager-cookie-banner__buttons{margin-top:16px}}')),document.head.appendChild(e)}}catch(o){console.error("vite-plugin-css-injected-by-js",o)}})();
(function(d){typeof define=="function"&&define.amd?define(d):d()})(function(){"use strict";var D=Object.defineProperty;var C=(d,p,y)=>p in d?D(d,p,{enumerable:!0,configurable:!0,writable:!0,value:y}):d[p]=y;var g=(d,p,y)=>C(d,typeof p!="symbol"?p+"":p,y);var k;const d={ar_SA:{"accept-all":"قبول الكل","decline-all":"رفض الكل","product-analytics-banner-description":'يستخدم هذا الموقع ملفات تعريف الارتباط والأدوات المماثلة، وبعضها توفره أطراف ثالثة (معا "أدوات"). وتمكننا هذه الأدوات والأطراف الثالثة من الوصول إلى بعض البيانات المتعلقة بالمستخدم والأنشطة وتسجيلها وتتبع تفاعلاتك مع هذا الموقع. وتستخدم هذه الأدوات والمعلومات المجمعة لتشغيل وتأمين هذا الموقع وتعزيز الأداء. تمكين بعض ميزات الموقع ووظائفه، وتحليل وتحسين أداء الموقع، وتخصيص تجربة المستخدم. لمزيد من التفاصيل',"product-analytics-banner-title":"قبل المتابعة مع Liferay","show-less":"إظهار أقل","show-more":"إظهار المزيد","show-more-accept-all":'إذا قمت بالنقر على "قبول الكل"، وتسمح بنشر كل هذه الأدوات وجمع المعلومات من جانبنا ومن جانب أطراف ثالثة لكل هذه الأغراض.',"show-more-decline-all":'إذا قمت بالنقر على "رفض الكل" عنوان IP الخاص بك والمعلومات الأخرى قد لا تزال تجمع ولكن فقط بواسطة الأدوات (بما في ذلك أدوات الطرف الثالث) الضرورية للتشغيل، تأمين وتمكين ميزات ووظائف الموقع الافتراضية.',"visite-our-privacy-policy":"قم بزيارة سياسة الخصوصية"},ca_ES:{"accept-all":"Accept All","decline-all":"Decline All","product-analytics-banner-description":'This website uses cookies and similar tools, some of which are provided by third parties (together "tools"). These tools enable us and the third parties to access and record certain user-related and activity data and to track your interactions with this website. These tools and the information collected are used to operate and secure this website, enhance performance, enable certain website features and functionality, analyze and improve website performance, and personalize user experience. For further detail',"product-analytics-banner-title":"Before You Continue with Liferay","show-less":"Show Less","show-more":"Show More","show-more-accept-all":'If you click "Accept All", you allow the deployment of all these tools and collection of the information by us and the third parties for all these purposes.',"show-more-decline-all":'If you click "Decline All" your IP address and other information may still be collected but only by tools (including third party tools) that are necessary to operate, secure and enable default website features and functionalities.',"visite-our-privacy-policy":"Visit our Privacy Policy"},de_DE:{"accept-all":"Alle akzeptieren","decline-all":"Alle ablehnen","product-analytics-banner-description":'Diese Website verwendet Cookies und ähnliche Tools, von denen einige von Dritten zur Verfügung gestellt werden (zusammen "Tools"). Diese Tools ermöglichen es uns und den Dritten, auf bestimmte Nutzer- und Aktivitätsdaten zuzugreifen und aufzuzeichnen und Ihre Interaktionen mit dieser Website zu verfolgen. Diese Tools und die gesammelten Informationen werden verwendet, um diese Website zu betreiben und zu sichern, die Leistung zu verbessern aktivieren Sie bestimmte Funktionen und Funktionen der Webseite, analysieren und verbessern Sie die Leistung der Website und personalisieren Sie das Benutzererlebnis. Für weitere Details',"product-analytics-banner-title":"Bevor Sie mit Liferay fortfahren","show-less":"Weniger anzeigen","show-more":"Mehr anzeigen","show-more-accept-all":'Wenn Sie auf "Alle akzeptieren" klicken, Sie erlauben den Einsatz all dieser Tools und die Erfassung der Informationen durch uns und Dritte zu all diesen Zwecken.',"show-more-decline-all":'Wenn Sie auf "Alle ablehnen" klicken, können Ihre IP-Adresse und andere Informationen noch gesammelt werden, aber nur durch Werkzeuge (einschließlich Drittanbieter-Tools), die für den Betrieb erforderlich sind, Sicher und aktivieren Sie die Standardfunktionen und Funktionalitäten.',"visite-our-privacy-policy":"Besuchen Sie unsere Datenschutzerklärung"},en_US:{"accept-all":"Accept All","decline-all":"Decline All","product-analytics-banner-description":'This website uses cookies and similar tools, some of which are provided by third parties (together "tools"). These tools enable us and the third parties to access and record certain user-related and activity data and to track your interactions with this website. These tools and the information collected are used to operate and secure this website, enhance performance, enable certain website features and functionality, analyze and improve website performance, and personalize user experience. For further detail',"product-analytics-banner-title":"Before You Continue with Liferay","show-less":"Show Less","show-more":"Show More","show-more-accept-all":'If you click "Accept All", you allow the deployment of all these tools and collection of the information by us and the third parties for all these purposes.',"show-more-decline-all":'If you click "Decline All" your IP address and other information may still be collected but only by tools (including third party tools) that are necessary to operate, secure and enable default website features and functionalities.',"visite-our-privacy-policy":"Visit our Privacy Policy"},es_ES:{"accept-all":"Aceptar todo","decline-all":"Rechazar todo","product-analytics-banner-description":'Este sitio web utiliza cookies y herramientas similares, algunas de las cuales son proporcionadas por terceros (en conjunto "herramientas"). Estas herramientas nos permiten a nosotros y a los terceros acceder y registrar ciertos datos relacionados con el usuario y la actividad y realizar un seguimiento de sus interacciones con este sitio web. Estas herramientas y la información recopilada se utilizan para operar y asegurar este sitio web, mejorar el rendimiento, permite ciertas funciones y funcionalidad del sitio web, analizar y mejorar el rendimiento del sitio web y personalizar la experiencia del usuario. Para más detalles',"product-analytics-banner-title":"Antes de continuar con Liferay","show-less":"Mostrar menos","show-more":"Mostrar más","show-more-accept-all":'Si haces clic en "Aceptar todos", permite el despliegue de todas estas herramientas y la recopilación de la información por nosotros y los terceros para todos estos fines.',"show-more-decline-all":'Si hace clic en "Rechazar todo" su dirección IP y otra información puede ser recolectada, pero sólo por herramientas (incluyendo herramientas de terceros) que son necesarias para operar, asegurar y habilitar las funciones y funciones predeterminadas del sitio web.',"visite-our-privacy-policy":"Visite nuestra Política de Privacidad"},fi_FI:{"accept-all":"Hyväksy Kaikki","decline-all":"Hylkää Kaikki","product-analytics-banner-description":'Tämä sivusto käyttää evästeitä ja vastaavia työkaluja, joista osa on kolmansien osapuolten tarjoamia (yhdessä "työkalut"). Nämä työkalut auttavat meitä ja kolmansia osapuolia pääsemään käsiksi ja tallentamaan tiettyjä käyttäjä- ja aktiivisuustietoja sekä seuraamaan vuorovaikutustasi tämän sivuston kanssa. Näitä työkaluja ja kerättyjä tietoja käytetään toimimaan ja suojaamaan tällä sivustolla, parantaa suorituskykyä, mahdollistaa tietyt sivuston ominaisuudet ja toiminnallisuuden, analysoida ja parantaa sivuston suorituskykyä ja muokata käyttäjäkokemusta. Tarkempia tietoja',"product-analytics-banner-title":"Ennen kuin jatkat Liferayn avulla","show-less":"Näytä Vähemmän","show-more":"Näytä Lisää","show-more-accept-all":'Jos klikkaat "Hyväksy kaikki", sallii kaikkien näiden välineiden käytön ja tietojen keräämisen meille ja kolmansille osapuolille kaikkiin näihin tarkoituksiin.',"show-more-decline-all":'Jos napsautat "Hylkää kaikki" IP-osoitteesi ja muut tiedot voidaan edelleen kerätä, mutta vain työkaluilla (mukaan lukien kolmannen osapuolen työkalut), jotka ovat tarpeen käyttää, turvallinen ja ota käyttöön oletussivuston ominaisuudet ja toiminnot.',"visite-our-privacy-policy":"Vieraile tietosuojakäytännössämme"},fr_FR:{"accept-all":"Accepter tout","decline-all":"Refuser tout","product-analytics-banner-description":`Ce site Web utilise des cookies et des outils similaires, dont certains sont fournis par des tiers (ensemble des "outils"). Ces outils nous permettent, ainsi qu'aux tiers, d'accéder et d'enregistrer certaines données relatives à l'utilisateur et à l'activité et de suivre vos interactions avec ce site Web. Ces outils et les informations recueillies sont utilisés pour exploiter et sécuriser ce site Web, améliorer les performances, activer certaines fonctionnalités et fonctionnalités du site, analyser et améliorer les performances du site Web et personnaliser l'expérience utilisateur. Pour plus de détails`,"product-analytics-banner-title":"Avant de continuer avec Liferay","show-less":"Afficher moins","show-more":"Afficher plus","show-more-accept-all":'Si vous cliquez sur "Tout accepter", vous autorisez le déploiement de tous ces outils et la collecte des informations par nous et les tiers à toutes ces fins.',"show-more-decline-all":`Si vous cliquez sur "Refuser tous" votre adresse IP et d'autres informations peuvent toujours être collectées, mais uniquement par des outils (y compris des outils de tiers) qui sont nécessaires pour fonctionner, sécuriser et activer les fonctionnalités par défaut du site Web.`,"visite-our-privacy-policy":"Visitez notre politique de confidentialité"},hu_HU:{"accept-all":"Accept All","decline-all":"Decline All","product-analytics-banner-description":'This website uses cookies and similar tools, some of which are provided by third parties (together "tools"). These tools enable us and the third parties to access and record certain user-related and activity data and to track your interactions with this website. These tools and the information collected are used to operate and secure this website, enhance performance, enable certain website features and functionality, analyze and improve website performance, and personalize user experience. For further detail',"product-analytics-banner-title":"Before You Continue with Liferay","show-less":"Show Less","show-more":"Show More","show-more-accept-all":'If you click "Accept All", you allow the deployment of all these tools and collection of the information by us and the third parties for all these purposes.',"show-more-decline-all":'If you click "Decline All" your IP address and other information may still be collected but only by tools (including third party tools) that are necessary to operate, secure and enable default website features and functionalities.',"visite-our-privacy-policy":"Visit our Privacy Policy"},ja_JP:{"accept-all":"すべて承認","decline-all":"すべて拒否","product-analytics-banner-description":"本ウェブサイトではクッキーおよび類似のツールを使用しており、その一部は第三者(以下「ツール」といいます)によって提供されています。 これらのツールは、当社および第三者が特定のユーザー関連およびアクティビティデータにアクセスおよび記録し、本ウェブサイトとのやり取りを追跡することを可能にします。 これらのツールおよび収集された情報は、本ウェブサイトの運用と保護、パフォーマンスの向上に使用されます。 特定のウェブサイト機能と機能を有効にし、ウェブサイトのパフォーマンスを分析し、改善し、ユーザーエクスペリエンスをパーソナライズします。 詳細はこちら","product-analytics-banner-title":"Liferayを続ける前","show-less":"縮小表示","show-more":"詳細を表示","show-more-accept-all":"「すべて受け入れる」をクリックした場合 これらすべてのツールの展開と情報の収集を許可する 我々と第三者によるこれらの目的のために","show-more-decline-all":"「すべて拒否」をクリックすると、IPアドレスおよびその他の情報は引き続き収集されることがありますが、動作に必要なツール(サードパーティのツールを含む)によってのみ収集されることがあります。 安全でデフォルトのウェブサイト機能と機能を有効にします。","visite-our-privacy-policy":"プライバシーポリシーをご覧ください"},nl_NL:{"accept-all":"Accepteer alles","decline-all":"Alles afwijzen","product-analytics-banner-description":'Deze website maakt gebruik van cookies en soortgelijke hulpmiddelen, waarvan sommige worden geleverd door derden (samen "tools"). Deze tools stellen ons en derden in staat om toegang te krijgen tot bepaalde gebruikers- en activiteitgegevens en om uw interacties met deze website te volgen. Deze tools en de verzamelde informatie worden gebruikt om deze website te beveiligen, prestaties te verbeteren, schakel bepaalde website-functies en functionaliteit, analyseer en verbeter website prestaties en personaliseer gebruikerservaring. Voor meer details',"product-analytics-banner-title":"Voordat je doorgaat met Liferay","show-less":"Minder weergeven","show-more":"Meer weergeven","show-more-accept-all":'Als u op "Accepteer alles" klikt staat u toe al deze instrumenten in te zetten en de informatie van ons en de derde partijen te verzamelen voor al deze doeleinden.',"show-more-decline-all":'Als u klikt op "Weiger Alle" dan kan uw IP-adres en andere informatie nog steeds worden verzameld, maar alleen door tools (inclusief functies van derden) die nodig zijn om te werken, veilige en standaard website functies en functies inschakelen.',"visite-our-privacy-policy":"Bezoek ons privacybeleid"},pt_BR:{"accept-all":"Aceitar Todos","decline-all":"Recusar Todos","product-analytics-banner-description":'Este site usa cookies e ferramentas semelhantes, alguns dos quais são fornecidos por terceiros (juntos "ferramentas"). Essas ferramentas permitem-nos que nós e os terceiros acessem e registrassem dados relacionados aos usuários e atividades e rastreassem suas interações com este site. Estas ferramentas e as informações coletadas são usadas para operar e proteger este site, melhorar o desempenho, permitir certos recursos e funcionalidades do site, analise e melhore o desempenho do site e personalize a experiência do usuário. Para mais detalhes',"product-analytics-banner-title":"Antes de continuar com Liferay","show-less":"Mostrar menos","show-more":"Mostrar mais","show-more-accept-all":'Se você clicar em "Aceitar Tudo", permite a implantação de todas estas ferramentas e a recolha de informações por nós e por terceiros para todos estes fins.',"show-more-decline-all":'Se você clicar em "Recusar Todos" seu endereço IP e outras informações ainda podem ser coletadas, mas apenas por ferramentas (incluindo ferramentas de terceiros) que são necessárias para operar, proteger e habilitar recursos e funcionalidades padrão do site.',"visite-our-privacy-policy":"Visite nossa Política de Privacidade"},zh_CN:{"accept-all":"全部接受","decline-all":"拒绝所有","product-analytics-banner-description":"这个网站使用cookie和类似的工具，其中一些是由第三方提供的(结合“工具”)。 这些工具使我们和第三方能够访问和记录某些与用户有关的数据和活动数据，并跟踪您与该网站的互动。 这些工具和收集的信息被用来操作和维护这个网站，提高绩效。 启用某些网站功能和功能，分析和改进网站性能，个性化用户体验。 更多详情","product-analytics-banner-title":"继续Liferay前","show-less":"显示更多","show-more":"显示更多","show-more-accept-all":'如果您点击"接受全部", 你允许我们和第三方为所有这些目的部署所有这些工具和收集信息。',"show-more-decline-all":'如果您点击"所有"，您的IP地址和其他信息仍然可以收集，但只能通过操作所必需的工具(包括第三方工具) 安全并启用默认网站功能和功能。',"visite-our-privacy-policy":"访问我们的隐私政策"}};class p{constructor(){g(this,"FALLBACK_LANGUAGE","en_US")}get(e){var a,i,t,s,r;const n=((t=(i=(a=window.Liferay)==null?void 0:a.ThemeDisplay)==null?void 0:i.getLanguageId)==null?void 0:t.call(i))||this.FALLBACK_LANGUAGE;return((s=d[n])==null?void 0:s[e])??((r=d[this.FALLBACK_LANGUAGE])==null?void 0:r[e])??this.returnKey(e)}returnKey(e){return console.warn(`[Product Experience Manager] Missing translation for key "${e}"`),e}defaultLanguageId(){var e,n,a,i,t,s;return((a=(n=(e=window.Liferay)==null?void 0:e.ThemeDisplay)==null?void 0:n.getLanguageId)==null?void 0:a.call(n))||((s=(t=(i=window.Liferay)==null?void 0:i.ThemeDisplay)==null?void 0:t.getDefaultLanguageId)==null?void 0:s.call(t))||this.FALLBACK_LANGUAGE}}class y{render({onAcceptAll:e,onRejectAll:n}){var f,h,w,v;const a=c=>new DOMParser().parseFromString(c,"text/html").body,i=(w=(h=(f=window==null?void 0:window.Liferay)==null?void 0:f.ThemeDisplay)==null?void 0:h.getPathThemeImages)==null?void 0:w.call(h),t=new p,s=`<svg class="lexicon-icon lexicon-icon-angle-down-small"><use href="${i}/clay/icons.svg#angle-down-small"></use></svg>`,r=`<svg class="lexicon-icon lexicon-icon-angle-up-small"><use href="${i}/clay/icons.svg#angle-up-small"></use></svg>`,m=`
      <div id="productExperienceManagerCookieBanner" class="product-experience-manager-cookie-banner">
        <div class="product-experience-manager-cookie-banner__container">
          <div class="product-experience-manager-cookie-banner__box-content">
            <div class="product-experience-manager-cookie-banner__box-content__title">${t.get("product-analytics-banner-title")}</div>
            <div class="product-experience-manager-cookie-banner__box-content__description">
              ${t.get("product-analytics-banner-description")}
              <a target="_blank" rel="noopener noreferrer" href="https://www.liferay.com/privacy-policy">${t.get("visite-our-privacy-policy")}</a>.

              <div id="showMoreContent" data-show-more="true" style="display: none">
                <br />
                ${t.get("show-more-accept-all")}
                <br /><br />
                ${t.get("show-more-decline-all")}
              </div>

              <button class="product-experience-manager-cookie-banner__show-more-button" id="showMoreButton">
                <span id="showMoreTitle">${t.get("show-more")}</span>
                <span id="showMoreIcon">${s}</span>
              </button>
            </div>
          </div>

          <div class="product-experience-manager-cookie-banner__buttons">
            <button id="acceptAllButton" class="product-experience-manager-cookie-banner__button">${t.get("accept-all")}</button>
            <button id="rejectAllButton" class="product-experience-manager-cookie-banner__button">${t.get("decline-all")}</button>
          </div>
        </div>
